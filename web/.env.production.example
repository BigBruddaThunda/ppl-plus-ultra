# Ppl± Production Environment Variables
# Copy to Vercel Dashboard > Settings > Environment Variables
# NEVER commit actual values to the repo

# Supabase — Production project (separate from dev)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — Live mode keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — Live mode products
STRIPE_TIER1_PRICE_ID=price_...
STRIPE_TIER2_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_TIER1_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_TIER2_PRICE_ID=price_...
